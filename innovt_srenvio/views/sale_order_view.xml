<odoo>

    <record id="view_sale_order_form_with_provider_srenvio" model="ir.ui.view">
        <field name="name">sale.order.form.provider.srenvio</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="delivery.view_order_form_with_carrier"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='carrier_id']" position='after'>
                <field name="carrier_delivery_type" invisible="True"/>
                <field name="srenvio_provider" attrs="{ 'invisible': [('carrier_delivery_type','!=','srenvio')] }"/>
                <field name="srenvio_service_level_code" attrs="{ 'invisible': [('carrier_delivery_type','!=','srenvio')] }"/>
            </xpath>
        </field>
    </record>

</odoo>
