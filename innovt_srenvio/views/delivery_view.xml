<odoo>

    <record id="view_delivery_carrier_form_with_provider_srenvio" model="ir.ui.view">
        <field name="name">delivery.carrier.form.provider.srenvio</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='destination']" position='before'>
                <page string="SrEnvio Configuration" attrs="{'invisible': [('delivery_type', '!=', 'srenvio')]}">
                    <group>
                        <group>
                            <field name="srenvio_token" attrs="{'required': [('delivery_type', '=', 'srenvio')]}"/>
                            <field name="srenvio_default_packaging_id" attrs="{'required': [('delivery_type', '=', 'srenvio')]}" domain="[('package_carrier_type', '=', 'srenvio')]"/>
                        </group>
                    </group>
                    <group string='SrEnvio Tutorial' attrs="{'invisible': [('delivery_type', '!=', 'srenvio')]}">
                        <ul>
                            <li>
                                <b>Vaya al sitio web de Sr Envio para crear una cuenta de <a href="https://demo.srenvio.com/users/sign_up" target='_blank'>Pruebas</a>
                                ó <a href="https://app.srenvio.com/users/sign_up" target='_blank'>Producción</a>.
                            </li>

                            <li>
                                <b/>
                                Una vez creado su cuenta, solicite
                                <a href='https://srenvio.github.io/api-doc/?shell#authentication' target='_blank'>
                                    el token de pruebas o de producción.
                                </a>
                            </li>
                        </ul>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
