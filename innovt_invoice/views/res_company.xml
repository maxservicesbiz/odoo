<odoo>
    <data>
        <record model="ir.ui.view" id="msc_iuv_res_company_page_settings_form">
            <field name="name">Res company page settings from</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Invoice">
                        <group>
                            <group>
                                <field name="fiscal_name"/>
                                <field name="property_account_position_id"/>
                            </group>
                            <group>
                                <field name="invoice_series"/>
                                <!--field name="voucher_series"/-->
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="file_cer" filters="*.cer"/>
                                <field name="password" password="True"/>
                            </group>
                            <group>
                                <field name="file_key" filters="*.key"/>
                                <button name="sync_csd" type="object" string="Sync Csd"
                                        confirm="Are you secure Sync files?"/>
                            </group>
                        </group>

                    </page>
                </xpath>

            </field>
        </record>

        <record id="it_innovt_invoice_iuv_string_vat_to_rfc" model="ir.ui.view">
            <field name="name">Res Company string VAT to RFC</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base_vat_autocomplete.res_company_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='vat']" position="attributes">
                    <attribute name="string">RFC</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>