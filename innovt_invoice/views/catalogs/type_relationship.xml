<odoo>
    <data>
        <record model='ir.ui.view' id='msc_iuv_type_relationship_tree'>
            <field name='name'>type.relationship.tree</field>
            <field name='model'>type.relationship</field>
            <field name='arch' type='xml'>
                <tree>
                    <field name='code'/>
                    <field name='name'/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="msc_iuv_type_relationship_form">
            <field name="name">type.relationship.form</field>
            <field name="model">type.relationship</field>
            <field name="arch" type="xml">
                <form>
                    <header/>
                    <sheet>
                        <group>
                            <field name='code'/>
                            <field name='name'/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="msc_iac_type_relationship_action" model="ir.actions.act_window">
            <field name="name">Type of relationship</field>
            <field name="res_model">type.relationship</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="msc_mi_type_relationship" name="Type of relationship" sequence="11" parent="account.account_management_menu"
                  action="msc_iac_type_relationship_action"/>

    </data>
</odoo>