<odoo>
    <data>
        <record model='ir.ui.view' id='msc_iuv_merchandise_use_tree'>
            <field name='name'>cfdi.use.tree</field>
            <field name='model'>cfdi.use</field>
            <field name='arch' type='xml'>
                <tree>
                    <field name='code'/>
                    <field name='name'/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="msc_iuv_merchandise_use_form">
            <field name="name">cfdi.use.form</field>
            <field name="model">cfdi.use</field>
            <field name="arch" type="xml">
                <form>
                    <header/>
                    <sheet>
                        <group>
                            <field name='code'/>
                            <field name='name'/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="msc_iac_merchandise_use_action" model="ir.actions.act_window">
            <field name="name">Cfdi use</field>
            <field name="res_model">cfdi.use</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="msc_mi_merchandise_use" name="Cfdi use" sequence="8" parent="account.account_management_menu"
                  action="msc_iac_merchandise_use_action"/>

    </data>
</odoo>