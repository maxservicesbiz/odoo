<odoo>
    <data>
        <record model='ir.ui.view' id='msc_iuv_suburb_tree'>
            <field name='name'>res.country.suburb.tree</field>
            <field name='model'>res.country.suburb</field>
            <field name='arch' type='xml'>
                <tree>
                    <field name='code'/>
                    <field name='name'/>
                    <field name='zip_code'/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="msc_iuv_suburb_form">
            <field name="name">res.country.suburb.form</field>
            <field name="model">res.country.suburb</field>
            <field name="arch" type="xml">
                <form>
                    <header/>
                    <sheet>
                        <group>
                            <field name='code'/>
                            <field name='name'/>
                            <field name='zip_code'/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="msc_iac_suburb_action" model="ir.actions.act_window">
            <field name="name">Suburb</field>
            <field name="res_model">res.country.suburb</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="msc_mi_suburb" name="Suburb" parent="contacts.menu_localisation"
                  action="msc_iac_suburb_action"/>

    </data>
</odoo>