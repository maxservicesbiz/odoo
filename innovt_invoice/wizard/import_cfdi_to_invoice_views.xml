<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="iuv_ir_innovt_invoice_import_cifd_to_invoice_wizard_form_view" model="ir.ui.view">
            <field name="name">import.cfdi.to.invoice.form.view</field>
            <field name="model">innovt_invoice.import_cfdi_to_invoice</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group string="Archivos CFDI">
                            <field name="cfdi_xml" required="1"/>
                            <field name="cfdi_pdf"/>
                        </group>
                        <group string="Configuración">
                            <field name="create_products"/>
                            <field name="validate_uuid"/>
                        </group>
                    </group>
                    <footer>
                        <button name="import_cfdi" string="Importar" type="object" class="oe_highlight"/>
                        <button string="Cancelar" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="iaa_it_innovt_invoice_import_cifd_to_invoice_act_window" model="ir.actions.act_window">
            <field name="name">Importar CFDI a Factura</field>
            <field name="res_model">innovt_invoice.import_cfdi_to_invoice</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="iuv_ir_innovt_invoice_import_cifd_to_invoice_wizard_form_view"/>
            <field name="target">new</field>
        </record>

        <menuitem
                id="mi_it_innovt_invoice_import_cifd_to_invoice_menu"
                name="Importar CFDI"
                parent="account.menu_finance_payables_documents"
                sequence="20"
                action="iaa_it_innovt_invoice_import_cifd_to_invoice_act_window"
                groups="account.group_account_invoice"/>
    </data>
</odoo>