<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="acquirer_form_mercadopago" model="ir.ui.view">
            <field name="name">acquirer.form.mercadopago</field>
            <field name="model">payment.acquirer</field>
            <field name="inherit_id" ref="payment.acquirer_form"/>
            <field name="arch" type="xml">
                <xpath expr='//group[@name="acquirer"]' position='after'>
                    <group attrs="{'invisible': [('provider', '!=', 'mercadopago')]}">
                        <field name="mercadopago_client_id"/>
                        <field name="mercadopago_client_secret"/>
                        <a colspan="2" href="https://www.mercadopago.com.mx/developers/es/guides/faqs/credentials/" target="_blank">Cómo obtener credentiales?</a>
                    </group>
                </xpath>
            </field>
        </record>
